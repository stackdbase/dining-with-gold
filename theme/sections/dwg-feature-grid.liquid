{% liquid
  assign card_bg = section.settings.card_background | default: '#FBF1E2'
  assign page_bg = section.settings.page_background | default: '#FFFFFF'
  assign accent = section.settings.accent_color | default: '#D4A574'
  assign text_color = section.settings.text_color | default: '#1C1C1C'
%}

<section
  class="dwg-feature-grid"
  style="
    --dwg-fg-card: {{ card_bg }};
    --dwg-fg-page: {{ page_bg }};
    --dwg-fg-accent: {{ accent }};
    --dwg-fg-text: {{ text_color }};
  "
>
  <div class="dwg-feature-grid__wrap page-width">
    <div class="dwg-feature-grid__card">
      <div class="dwg-feature-grid__content">
        {% if section.settings.heading != blank %}
          <h2 class="dwg-feature-grid__title">{{ section.settings.heading }}</h2>
        {% endif %}

        {% if section.blocks.size > 0 %}
          <div class="dwg-feature-grid__items">
            {% for block in section.blocks %}
              <div class="dwg-feature-grid__item" {{ block.shopify_attributes }}>
                {% if block.settings.title != blank %}
                  <h3 class="dwg-feature-grid__item-title">{{ block.settings.title }}</h3>
                {% endif %}
                {% if block.settings.description != blank %}
                  <p class="dwg-feature-grid__item-text">{{ block.settings.description }}</p>
                {% endif %}
                {% if block.settings.badge_text != blank %}
                  <span class="dwg-feature-grid__badge">
                    <span class="dwg-feature-grid__badge-icon" aria-hidden="true">
                      {%- case block.settings.badge_icon -%}
                        {%- when 'flame' -%}
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2c1 4 4 5 4 9a4 4 0 1 1-8 0c0-2 1-3 1-5 0 0 2 1 3-4z"/><path d="M12 22a6 6 0 0 0 6-6c0-3-2-4-3-7"/></svg>
                        {%- when 'bag' -%}
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 8h14l-1.2 12H6.2L5 8z"/><path d="M9 8V6a3 3 0 0 1 6 0v2"/></svg>
                        {%- when 'check' -%}
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l2.4 1.5 2.8-.4 1.5 2.4 2.4 1.5-.4 2.8L22 12l-1.3 2.2.4 2.8-2.4 1.5-1.5 2.4-2.8-.4L12 22l-2.4-1.5-2.8.4-1.5-2.4L2.9 17l.4-2.8L2 12l1.3-2.2-.4-2.8 2.4-1.5L6.8 3.1l2.8.4L12 2z"/><path d="M9 12l2 2 4-4"/></svg>
                        {%- when 'fork' -%}
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M7 2v8a2 2 0 0 0 4 0V2"/><path d="M9 10v12"/><path d="M16 2c-1 0-3 2-3 5s2 5 3 5"/><path d="M16 12v10"/></svg>
                        {%- when 'spark' -%}
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v4M12 17v4M3 12h4M17 12h4M5.6 5.6l2.8 2.8M15.6 15.6l2.8 2.8M5.6 18.4l2.8-2.8M15.6 8.4l2.8-2.8"/></svg>
                        {%- when 'leaf' -%}
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 20c0-9 7-16 16-16 0 9-7 16-16 16z"/><path d="M4 20c4-4 8-8 12-12"/></svg>
                      {%- endcase -%}
                    </span>
                    <span class="dwg-feature-grid__badge-text">{{ block.settings.badge_text }}</span>
                  </span>
                {% endif %}
              </div>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <div class="dwg-feature-grid__media">
        {% if section.settings.image != blank %}
          {{
            section.settings.image
            | image_url: width: 1000
            | image_tag:
              class: 'dwg-feature-grid__image',
              sizes: '(min-width: 750px) 40vw, 80vw',
              widths: '300, 500, 700, 1000',
              loading: 'lazy',
              alt: section.settings.image.alt | default: section.settings.heading
          }}
        {% else %}
          <div class="dwg-feature-grid__image dwg-feature-grid__image--placeholder">
            {{ 'product-2' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .dwg-feature-grid {
    background-color: var(--dwg-fg-page);
    padding-block: 0;
  }

  .dwg-feature-grid__card {
    background-color: var(--dwg-fg-card);
    border-radius: 24px;
    padding: clamp(24px, 4vw, 56px);
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(20px, 3vw, 40px);
    align-items: center;
    color: var(--dwg-fg-text);
  }

  @media screen and (min-width: 750px) {
    .dwg-feature-grid__card {
      grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
    }
  }

  .dwg-feature-grid__title {
    margin: 0 0 24px;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    line-height: 1.1;
    font-weight: 800;
  }

  .dwg-feature-grid__items {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  @media screen and (min-width: 600px) {
    .dwg-feature-grid__items {
      grid-template-columns: 1fr 1fr;
      column-gap: 40px;
      row-gap: 28px;
    }
  }

  .dwg-feature-grid__item-title {
    margin: 0 0 8px;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--dwg-fg-text);
    line-height: 1.3;
  }

  .dwg-feature-grid__item-text {
    margin: 0 0 12px;
    font-size: 0.9rem;
    line-height: 1.55;
    color: rgba(28, 28, 28, 0.75);
  }

  .dwg-feature-grid__badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--dwg-fg-accent);
    font-size: 0.85rem;
    font-weight: 500;
  }

  .dwg-feature-grid__badge-icon {
    width: 22px;
    height: 22px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--dwg-fg-accent);
  }

  .dwg-feature-grid__badge-icon svg {
    width: 100%;
    height: 100%;
  }

  .dwg-feature-grid__media {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .dwg-feature-grid__image {
    display: block;
    width: 100%;
    max-width: 380px;
    height: auto;
    object-fit: contain;
  }

  .dwg-feature-grid__image--placeholder {
    aspect-ratio: 1 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(28, 28, 28, 0.18);
  }

  @media screen and (max-width: 749px) {
    .dwg-feature-grid__card {
      padding: 24px 20px;
    }
    .dwg-feature-grid__title {
      font-size: 1.6rem;
      margin-bottom: 16px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "DWG: Feature grid",
  "tag": "section",
  "class": "section--dwg-feature-grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Big Heat, Anywhere"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "page_background",
      "label": "Page background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#FBF1E2"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Badge accent",
      "default": "#D4A574"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Body text",
      "default": "#1C1C1C"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Instant Kick"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Add rich chilli heat to meals in seconds."
        },
        {
          "type": "select",
          "id": "badge_icon",
          "label": "Badge icon",
          "options": [
            { "value": "flame", "label": "Flame" },
            { "value": "bag", "label": "Bag" },
            { "value": "check", "label": "Check seal" },
            { "value": "fork", "label": "Fork" },
            { "value": "spark", "label": "Spark" },
            { "value": "leaf", "label": "Leaf" }
          ],
          "default": "flame"
        },
        {
          "type": "text",
          "id": "badge_text",
          "label": "Badge text",
          "default": "Bold spice, fast"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "DWG: Feature grid",
      "blocks": [
        { "type": "feature", "settings": { "title": "Instant Kick", "description": "Add rich chilli heat to meals in seconds.", "badge_icon": "flame", "badge_text": "Bold spice, fast" } },
        { "type": "feature", "settings": { "title": "Travel Ready", "description": "The compact bottle is easy to carry every day.", "badge_icon": "bag", "badge_text": "Fits your bag" } },
        { "type": "feature", "settings": { "title": "No-Mess Design", "description": "A secure seal helps keep spills out of your bag.", "badge_icon": "check", "badge_text": "Leak-proof cap" } },
        { "type": "feature", "settings": { "title": "Everyday Upgrade", "description": "Perfect for rice, noodles, eggs, and grilled meats.", "badge_icon": "fork", "badge_text": "Great on anything" } }
      ]
    }
  ]
}
{% endschema %}
