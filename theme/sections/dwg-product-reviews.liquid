{%- liquid
  # ============================================================
  # DWG: Product Reviews — fully owned, fully branded
  # ------------------------------------------------------------
  # Reads individual reviews from the MERCHANT-OWNED metaobject
  #   shop.metaobjects.product_review  (storefront public_read)
  # Fields: rating(int 1-5), title, body, author, country,
  #         status(pending|published), created_on(date_time),
  #         product(product_reference), verified_buyer(boolean)
  # Submit form POSTs JSON to the app-proxy endpoint
  #   (section setting `submit_endpoint`, default /apps/reviews/submit)
  # which creates a `pending` metaobject via the Admin API.
  # Only status == 'published' reviews render here (moderation).
  # ============================================================

  assign s = section.settings
  assign accent = s.accent_color | default: '#C9882A'
  assign dark = s.text_color | default: '#1C1C1C'
  assign cream = s.background_color | default: '#FAF7F2'
  assign card = s.card_color | default: '#FFFFFF'

  assign product = closest.product | default: product

  # --- aggregate the published reviews for this product ---
  assign total = 0
  assign count = 0
  assign c5 = 0
  assign c4 = 0
  assign c3 = 0
  assign c2 = 0
  assign c1 = 0
  assign all_reviews = shop.metaobjects.product_review.values

  for r in all_reviews
    if r.status.value != 'published'
      continue
    endif
    if product != blank and r.product.value.id != product.id
      continue
    endif
    assign rt = r.rating.value | plus: 0
    assign total = total | plus: rt
    assign count = count | plus: 1
    case rt
      when 5
        assign c5 = c5 | plus: 1
      when 4
        assign c4 = c4 | plus: 1
      when 3
        assign c3 = c3 | plus: 1
      when 2
        assign c2 = c2 | plus: 1
      else
        assign c1 = c1 | plus: 1
    endcase
  endfor

  assign avg = 0
  if count > 0
    assign avg = total | times: 1.0 | divided_by: count
  endif
  assign avg_rounded = avg | round: 1

  # editor preview: show sample numbers so the layout isn't blank
  if request.design_mode and count == 0
    assign avg_rounded = 4.8
    assign count = 24
    assign c5 = 20
    assign c4 = 3
    assign c3 = 1
    assign c2 = 0
    assign c1 = 0
  endif

  assign full_stars = avg | floor
  assign has_half = false
  assign rem = avg | minus: full_stars
  if rem >= 0.25 and rem < 0.75
    assign has_half = true
  elsif rem >= 0.75
    assign full_stars = full_stars | plus: 1
  endif
  assign half_pos = full_stars | plus: 1
-%}

<section
  class="dwg-reviews"
  id="dwg-reviews-{{ section.id }}"
  style="
    --dwgr-accent: {{ accent }};
    --dwgr-dark: {{ dark }};
    --dwgr-cream: {{ cream }};
    --dwgr-card: {{ card }};
  "
>
  {%- comment -%} ---- reusable star SVG symbol ---- {%- endcomment -%}
  <svg class="dwgr-svg-defs" aria-hidden="true" focusable="false">
    <defs>
      <linearGradient id="dwgr-half-{{ section.id }}" x1="0" x2="100%" y1="0" y2="0">
        <stop offset="50%" stop-color="var(--dwgr-accent)"></stop>
        <stop offset="50%" stop-color="rgba(28,28,28,0.18)"></stop>
      </linearGradient>
      <symbol id="dwgr-star-{{ section.id }}" viewBox="0 0 32 32">
        <path d="M31.547 12a.848.848 0 00-.677-.577l-9.427-1.376-4.224-8.532a.847.847 0 00-1.516 0l-4.218 8.534-9.427 1.355a.847.847 0 00-.467 1.467l6.823 6.664-1.612 9.375a.847.847 0 001.23.893l8.428-4.434 8.432 4.432a.847.847 0 001.229-.894l-1.615-9.373 6.822-6.665a.845.845 0 00.214-.869z"/>
      </symbol>
    </defs>
  </svg>

  <div class="dwg-reviews__inner page-width">
    <header class="dwg-reviews__top">
      <div class="dwg-reviews__summary">
        {%- if s.eyebrow != blank -%}
          <p class="dwg-reviews__eyebrow">{{ s.eyebrow }}</p>
        {%- endif -%}
        {%- if s.heading != blank -%}
          <h2 class="dwg-reviews__heading">{{ s.heading }}</h2>
        {%- endif -%}

        {%- if count > 0 -%}
          <div class="dwg-reviews__score">
            <span class="dwg-reviews__avg">{{ avg_rounded }}</span>
            <span class="dwg-reviews__stars" aria-label="{{ avg_rounded }} out of 5 stars">
              {%- for i in (1..5) -%}
                <svg class="dwgr-star" viewBox="0 0 32 32" role="presentation">
                  {%- if i <= full_stars -%}
                    <use href="#dwgr-star-{{ section.id }}" fill="var(--dwgr-accent)"></use>
                  {%- elsif has_half and i == half_pos -%}
                    <use href="#dwgr-star-{{ section.id }}" fill="url(#dwgr-half-{{ section.id }})"></use>
                  {%- else -%}
                    <use href="#dwgr-star-{{ section.id }}" fill="rgba(28,28,28,0.18)"></use>
                  {%- endif -%}
                </svg>
              {%- endfor -%}
            </span>
            <span class="dwg-reviews__count">{{ count }} {% if count == 1 %}review{% else %}reviews{% endif %}</span>
          </div>

          {%- if s.show_histogram -%}
            <div class="dwg-reviews__histogram">
              {%- assign rows = '5,4,3,2,1' | split: ',' -%}
              {%- for row in rows -%}
                {%- liquid
                  case row
                    when '5'
                      assign rc = c5
                    when '4'
                      assign rc = c4
                    when '3'
                      assign rc = c3
                    when '2'
                      assign rc = c2
                    else
                      assign rc = c1
                  endcase
                  assign pct = 0
                  if count > 0
                    assign pct = rc | times: 100 | divided_by: count
                  endif
                -%}
                <div class="dwg-reviews__hist-row">
                  <span class="dwg-reviews__hist-label">{{ row }}★</span>
                  <span class="dwg-reviews__hist-track"><span class="dwg-reviews__hist-fill" style="width: {{ pct }}%;"></span></span>
                  <span class="dwg-reviews__hist-num">{{ rc }}</span>
                </div>
              {%- endfor -%}
            </div>
          {%- endif -%}
        {%- else -%}
          <p class="dwg-reviews__empty">{{ s.empty_text | default: 'No reviews yet — be the first to share your experience.' }}</p>
        {%- endif -%}

        {%- if s.show_form -%}
          <button type="button" class="dwg-reviews__write-btn" data-dwgr-open>
            {{ s.form_button_label | default: 'Write a review' }}
          </button>
        {%- endif -%}
      </div>
    </header>

    {%- comment -%} ---- review list ---- {%- endcomment -%}
    {%- if count > 0 -%}
      <ul class="dwg-reviews__list" role="list">
        {%- assign shown = 0 -%}
        {%- for r in all_reviews -%}
          {%- if r.status.value != 'published' -%}{%- continue -%}{%- endif -%}
          {%- if product != blank and r.product.value.id != product.id -%}{%- continue -%}{%- endif -%}
          {%- assign rt = r.rating.value | plus: 0 -%}
          {%- assign shown = shown | plus: 1 -%}
          <li class="dwg-reviews__item{% if shown > s.initial_visible %} is-hidden{% endif %}">
            <div class="dwg-reviews__item-stars" aria-label="{{ rt }} out of 5 stars">
              {%- for i in (1..5) -%}
                <svg class="dwgr-star dwgr-star--sm" viewBox="0 0 32 32" role="presentation">
                  <use href="#dwgr-star-{{ section.id }}" fill="{% if i <= rt %}var(--dwgr-accent){% else %}rgba(28,28,28,0.18){% endif %}"></use>
                </svg>
              {%- endfor -%}
            </div>
            {%- if r.title.value != blank -%}
              <p class="dwg-reviews__item-title">{{ r.title.value | escape }}</p>
            {%- endif -%}
            {%- if r.body.value != blank -%}
              <p class="dwg-reviews__item-body">{{ r.body.value | escape | newline_to_br }}</p>
            {%- endif -%}
            <p class="dwg-reviews__item-meta">
              <span class="dwg-reviews__item-author">{{ r.author.value | default: 'Verified customer' | escape }}</span>
              {%- if r.verified_buyer.value -%}
                <span class="dwg-reviews__verified">✓ Verified buyer</span>
              {%- endif -%}
              {%- if r.country.value != blank -%}
                <span class="dwg-reviews__item-loc">{{ r.country.value | escape }}</span>
              {%- endif -%}
              {%- if r.created_on.value != blank -%}
                <span class="dwg-reviews__item-date">{{ r.created_on.value | date: '%b %-d, %Y' }}</span>
              {%- endif -%}
            </p>
          </li>
        {%- endfor -%}
      </ul>

      {%- if shown > s.initial_visible -%}
        <button type="button" class="dwg-reviews__more" data-dwgr-more>
          {{ s.show_more_label | default: 'Show all reviews' }}
        </button>
      {%- endif -%}
    {%- endif -%}
  </div>

  {%- comment -%} ---- submit modal ---- {%- endcomment -%}
  {%- if s.show_form -%}
    <div class="dwg-reviews__modal" data-dwgr-modal hidden>
      <div class="dwg-reviews__modal-overlay" data-dwgr-close></div>
      <div class="dwg-reviews__modal-card" role="dialog" aria-modal="true" aria-labelledby="dwgr-form-title-{{ section.id }}">
        <button type="button" class="dwg-reviews__modal-x" data-dwgr-close aria-label="Close">×</button>
        <h3 class="dwg-reviews__form-title" id="dwgr-form-title-{{ section.id }}">{{ s.form_heading | default: 'Write a review' }}</h3>

        <form class="dwg-reviews__form" data-dwgr-form novalidate>
          <input type="hidden" name="product_id" value="{{ product.id }}">
          <input type="hidden" name="product_handle" value="{{ product.handle }}">
          {%- comment -%} honeypot — bots fill this, humans don't see it {%- endcomment -%}
          <div class="dwg-reviews__hp" aria-hidden="true">
            <label>Leave this empty<input type="text" name="company" tabindex="-1" autocomplete="off"></label>
          </div>

          <fieldset class="dwg-reviews__rating-input">
            <legend>Your rating</legend>
            <div class="dwg-reviews__star-input" data-dwgr-starinput>
              {%- assign star_order = '5,4,3,2,1' | split: ',' -%}
              {%- for i in star_order -%}
                <input type="radio" id="dwgr-star{{ i }}-{{ section.id }}" name="rating" value="{{ i }}" required>
                <label for="dwgr-star{{ i }}-{{ section.id }}" aria-label="{{ i }} stars">
                  <svg viewBox="0 0 32 32"><use href="#dwgr-star-{{ section.id }}"></use></svg>
                </label>
              {%- endfor -%}
            </div>
          </fieldset>

          <label class="dwg-reviews__field">
            <span>Name</span>
            <input type="text" name="author" required maxlength="80" autocomplete="name">
          </label>

          <label class="dwg-reviews__field">
            <span>Email <em>(not published)</em></span>
            <input type="email" name="email" required maxlength="120" autocomplete="email">
          </label>

          <label class="dwg-reviews__field">
            <span>Title</span>
            <input type="text" name="title" maxlength="120">
          </label>

          <label class="dwg-reviews__field">
            <span>Your review</span>
            <textarea name="body" rows="5" required maxlength="1500"></textarea>
          </label>

          {%- if s.turnstile_site_key != blank -%}
            <div class="cf-turnstile dwg-reviews__turnstile" data-sitekey="{{ s.turnstile_site_key }}" data-theme="light"></div>
          {%- endif -%}

          <button type="submit" class="dwg-reviews__submit">{{ s.submit_label | default: 'Submit review' }}</button>
          <p class="dwg-reviews__form-msg" data-dwgr-msg role="status" aria-live="polite"></p>
          <p class="dwg-reviews__form-note">{{ s.form_note | default: 'Reviews are checked before they appear.' }}</p>
        </form>
      </div>
    </div>
  {%- endif -%}
</section>

{%- if s.turnstile_site_key != blank -%}
  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
{%- endif -%}

<script>
  (function () {
    var root = document.getElementById('dwg-reviews-{{ section.id }}');
    if (!root) return;

    // reveal-all toggle
    var moreBtn = root.querySelector('[data-dwgr-more]');
    if (moreBtn) {
      moreBtn.addEventListener('click', function () {
        root.querySelectorAll('.dwg-reviews__item.is-hidden').forEach(function (el) {
          el.classList.remove('is-hidden');
        });
        moreBtn.remove();
      });
    }

    // modal open/close
    var modal = root.querySelector('[data-dwgr-modal]');
    function open() { if (modal) { modal.hidden = false; document.body.style.overflow = 'hidden'; } }
    function close() { if (modal) { modal.hidden = true; document.body.style.overflow = ''; } }
    root.querySelectorAll('[data-dwgr-open]').forEach(function (b) { b.addEventListener('click', open); });
    root.querySelectorAll('[data-dwgr-close]').forEach(function (b) { b.addEventListener('click', close); });
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape') close(); });

    // submit
    var form = root.querySelector('[data-dwgr-form]');
    if (!form) return;
    var msg = form.querySelector('[data-dwgr-msg]');
    var endpoint = {{ s.submit_endpoint | default: '/apps/reviews/submit' | json }};

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      msg.className = 'dwg-reviews__form-msg';
      msg.textContent = '';

      if (form.company && form.company.value) { return; } // honeypot tripped — silently drop
      if (!form.rating.value) { msg.textContent = 'Please choose a star rating.'; msg.classList.add('is-error'); return; }

      var tsEl = form.querySelector('[name="cf-turnstile-response"]');
      if (root.querySelector('.cf-turnstile') && (!tsEl || !tsEl.value)) {
        msg.textContent = 'Please complete the verification.'; msg.classList.add('is-error'); return;
      }

      var btn = form.querySelector('.dwg-reviews__submit');
      btn.disabled = true;
      var original = btn.textContent;
      btn.textContent = 'Sending…';

      var payload = {
        product_id: form.product_id.value,
        product_handle: form.product_handle.value,
        rating: form.rating.value,
        author: form.author.value,
        email: form.email.value,
        title: form.title.value,
        body: form.body.value,
        turnstile_token: tsEl ? tsEl.value : ''
      };

      fetch(endpoint, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify(payload)
      })
        .then(function (r) { return r.json().then(function (d) { return { ok: r.ok, d: d }; }); })
        .then(function (res) {
          if (res.ok) {
            form.reset();
            msg.textContent = {{ s.success_message | default: 'Thank you! Your review has been submitted and will appear after a quick check.' | json }};
            msg.classList.add('is-success');
            btn.textContent = 'Submitted ✓';
          } else {
            msg.textContent = (res.d && res.d.error) || 'Something went wrong. Please try again.';
            msg.classList.add('is-error');
            btn.disabled = false;
            btn.textContent = original;
          }
        })
        .catch(function () {
          msg.textContent = 'Network error. Please try again.';
          msg.classList.add('is-error');
          btn.disabled = false;
          btn.textContent = original;
        });
    });
  })();
</script>

{% stylesheet %}
  .dwg-reviews {
    background-color: var(--dwgr-cream);
    color: var(--dwgr-dark);
    padding-block: clamp(48px, 6vw, 88px);
  }

  .dwg-reviews__inner {
    max-width: 980px;
    margin: 0 auto;
  }

  .dwgr-svg-defs { position: absolute; width: 0; height: 0; }

  .dwgr-star { width: 1.1em; height: 1.1em; display: inline-block; vertical-align: middle; }
  .dwgr-star--sm { width: 0.95em; height: 0.95em; }

  .dwg-reviews__top { margin-bottom: clamp(28px, 4vw, 44px); }

  .dwg-reviews__eyebrow {
    margin: 0 0 10px;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--dwgr-accent);
  }

  .dwg-reviews__heading {
    margin: 0 0 18px;
    font-family: var(--font-heading--family, serif);
    font-size: clamp(1.6rem, 3.6vw, 2.4rem);
    line-height: 1.1;
    color: var(--dwgr-dark);
  }

  .dwg-reviews__score {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
    margin-bottom: 22px;
  }

  .dwg-reviews__avg {
    font-family: var(--font-heading--family, serif);
    font-size: 2.6rem;
    line-height: 1;
    font-weight: 700;
    color: var(--dwgr-dark);
  }

  .dwg-reviews__stars { font-size: 1.4rem; line-height: 1; color: var(--dwgr-accent); }

  .dwg-reviews__count {
    font-family: var(--font-body--family, sans-serif);
    font-size: 0.95rem;
    color: var(--dwgr-dark);
    opacity: 0.7;
  }

  .dwg-reviews__histogram {
    display: grid;
    gap: 7px;
    max-width: 360px;
    margin-bottom: 24px;
  }

  .dwg-reviews__hist-row {
    display: grid;
    grid-template-columns: 30px 1fr 28px;
    align-items: center;
    gap: 10px;
    font-size: 0.82rem;
    color: var(--dwgr-dark);
  }

  .dwg-reviews__hist-label { opacity: 0.7; }
  .dwg-reviews__hist-num { opacity: 0.6; text-align: right; font-variant-numeric: tabular-nums; }

  .dwg-reviews__hist-track {
    height: 8px;
    border-radius: 999px;
    background: rgba(28, 28, 28, 0.1);
    overflow: hidden;
  }

  .dwg-reviews__hist-fill {
    display: block;
    height: 100%;
    border-radius: 999px;
    background: var(--dwgr-accent);
  }

  .dwg-reviews__empty {
    font-size: 1.02rem;
    color: var(--dwgr-dark);
    opacity: 0.75;
    margin: 0 0 22px;
  }

  .dwg-reviews__write-btn,
  .dwg-reviews__submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 30px;
    border-radius: 12px;
    border: none;
    background: var(--dwgr-accent);
    color: #fff;
    font-family: var(--font-body--family, sans-serif);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
    transition: transform 0.15s ease, background-color 0.15s ease, opacity 0.15s ease;
  }

  .dwg-reviews__write-btn:hover,
  .dwg-reviews__submit:hover { background: #b07623; transform: translateY(-1px); }
  .dwg-reviews__submit:disabled { opacity: 0.65; cursor: default; transform: none; }

  /* ---- list ---- */
  .dwg-reviews__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 16px;
  }

  .dwg-reviews__item {
    background: var(--dwgr-card);
    border: 1px solid rgba(28, 28, 28, 0.08);
    border-radius: 14px;
    padding: 22px 24px;
  }

  .dwg-reviews__item.is-hidden { display: none; }

  .dwg-reviews__item-stars { color: var(--dwgr-accent); font-size: 1rem; margin-bottom: 10px; }

  .dwg-reviews__item-title {
    margin: 0 0 6px;
    font-family: var(--font-heading--family, serif);
    font-size: 1.08rem;
    font-weight: 700;
    color: var(--dwgr-dark);
  }

  .dwg-reviews__item-body {
    margin: 0 0 14px;
    font-size: 0.96rem;
    line-height: 1.6;
    color: var(--dwgr-dark);
    opacity: 0.88;
  }

  .dwg-reviews__item-meta {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
    font-size: 0.8rem;
    color: var(--dwgr-dark);
    opacity: 0.65;
  }

  .dwg-reviews__item-author { font-weight: 700; opacity: 1; }
  .dwg-reviews__verified { color: var(--dwgr-accent); font-weight: 700; opacity: 1; }

  .dwg-reviews__more {
    display: block;
    margin: 22px auto 0;
    padding: 12px 28px;
    border-radius: 12px;
    border: 1.5px solid rgba(28, 28, 28, 0.25);
    background: transparent;
    color: var(--dwgr-dark);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
    transition: border-color 0.15s ease, color 0.15s ease;
  }

  .dwg-reviews__more:hover { border-color: var(--dwgr-accent); color: var(--dwgr-accent); }

  /* ---- modal ---- */
  .dwg-reviews__modal {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }
  .dwg-reviews__modal[hidden] { display: none; }

  .dwg-reviews__modal-overlay {
    position: absolute;
    inset: 0;
    background: rgba(28, 28, 28, 0.55);
    backdrop-filter: blur(2px);
  }

  .dwg-reviews__modal-card {
    position: relative;
    background: var(--dwgr-card);
    border-radius: 16px;
    padding: clamp(24px, 4vw, 40px);
    width: 100%;
    max-width: 480px;
    max-height: 90vh;
    overflow-y: auto;
    box-shadow: 0 24px 60px rgba(28, 28, 28, 0.28);
  }

  .dwg-reviews__modal-x {
    position: absolute;
    top: 14px;
    right: 16px;
    background: none;
    border: none;
    font-size: 1.7rem;
    line-height: 1;
    color: var(--dwgr-dark);
    opacity: 0.5;
    cursor: pointer;
  }
  .dwg-reviews__modal-x:hover { opacity: 1; }

  .dwg-reviews__form-title {
    margin: 0 0 20px;
    font-family: var(--font-heading--family, serif);
    font-size: 1.5rem;
    color: var(--dwgr-dark);
  }

  .dwg-reviews__hp { position: absolute; left: -9999px; width: 1px; height: 1px; overflow: hidden; }

  .dwg-reviews__rating-input { border: none; padding: 0; margin: 0 0 18px; }
  .dwg-reviews__rating-input legend {
    padding: 0;
    margin-bottom: 8px;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--dwgr-dark);
  }

  /* star input: reverse-row so hover/checked can style preceding siblings */
  .dwg-reviews__star-input {
    display: inline-flex;
    flex-direction: row-reverse;
    justify-content: flex-end;
    gap: 4px;
  }
  .dwg-reviews__star-input input { position: absolute; opacity: 0; width: 0; height: 0; }
  .dwg-reviews__star-input label { cursor: pointer; color: rgba(28, 28, 28, 0.2); transition: color 0.1s ease; }
  .dwg-reviews__star-input label svg { width: 30px; height: 30px; display: block; }
  .dwg-reviews__star-input input:checked ~ label,
  .dwg-reviews__star-input label:hover,
  .dwg-reviews__star-input label:hover ~ label { color: var(--dwgr-accent); }
  .dwg-reviews__star-input input:focus-visible + label { outline: 2px solid var(--dwgr-accent); outline-offset: 2px; border-radius: 4px; }

  .dwg-reviews__field { display: block; margin-bottom: 16px; }
  .dwg-reviews__field > span {
    display: block;
    margin-bottom: 6px;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--dwgr-dark);
  }
  .dwg-reviews__field em { font-weight: 400; opacity: 0.6; font-style: normal; }

  .dwg-reviews__field input,
  .dwg-reviews__field textarea {
    width: 100%;
    padding: 11px 14px;
    border: 1px solid rgba(28, 28, 28, 0.2);
    border-radius: 10px;
    background: #fff;
    color: var(--dwgr-dark);
    font-family: var(--font-body--family, sans-serif);
    font-size: 0.95rem;
  }
  .dwg-reviews__field input:focus,
  .dwg-reviews__field textarea:focus {
    outline: none;
    border-color: var(--dwgr-accent);
    box-shadow: 0 0 0 3px rgba(201, 136, 42, 0.18);
  }

  .dwg-reviews__turnstile { margin-bottom: 14px; }

  .dwg-reviews__submit { width: 100%; margin-top: 4px; }

  .dwg-reviews__form-msg { margin: 12px 0 0; font-size: 0.9rem; min-height: 1.2em; }
  .dwg-reviews__form-msg.is-success { color: #2f7d4f; }
  .dwg-reviews__form-msg.is-error { color: #c0392b; }

  .dwg-reviews__form-note { margin: 10px 0 0; font-size: 0.78rem; opacity: 0.55; color: var(--dwgr-dark); }

  @media screen and (max-width: 600px) {
    .dwg-reviews__avg { font-size: 2.1rem; }
    .dwg-reviews__item { padding: 18px 18px; }
  }
{% endstylesheet %}

