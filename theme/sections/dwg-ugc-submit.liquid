    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "<p>Show us how you DWG. Tag us on Instagram or send us your clip — we feature new community videos every week.</p>"
    },
    {
      "type": "header",
      "content": "Instagram CTA"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram link",
      "info": "Your Instagram profile or tag URL"
    },
    {
      "type": "text",
      "id": "instagram_label",
      "label": "Instagram button label",
      "default": "TAG @DININGWITHGOLD"
    },
    {
      "type": "header",
      "content": "Email CTA"
    },
    {
      "type": "text",
      "id": "email_address",
      "label": "Email address",
      "default": "diningwithgold@outlook.com"
    },
    {
      "type": "text",
      "id": "email_label",
      "label": "Email button label",
      "default": "EMAIL YOUR CLIP"
    },
    {
      "type": "text",
      "id": "email_subject",
      "label": "Email subject line",
      "default": "DWG Community Submission"
    },
    {
      "type": "textarea",
      "id": "email_body",
      "label": "Email body prefill",
      "default": "Hi DWG team, here is my video for the Loved By You wall:"
    },
    {
      "type": "header",
      "content": "Fine print"
    },
    {
      "type": "text",
      "id": "fineprint",
      "label": "Fine print",
      "default": "By submitting you agree to let DWG share your clip across our channels."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#1C1C1C"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#C9882A"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#F5EFE2"
    }
  ],
  "presets": [
    {
      "name": "DWG: UGC Submit CTA",
      "settings": {
        "instagram_url": "https://www.instagram.com/diningwithgold/",
        "email_address": "diningwithgold@outlook.com"
      }
    }
  ]
}
{% endschema %}
