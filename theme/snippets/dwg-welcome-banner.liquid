  /* ------- Mobile (< 750) — stack: image on top as a banner, form below ------- */
  @media screen and (max-width: 749px) {
    .dwg-welcome-banner {
      padding: 16px;
    }

    .dwg-welcome-banner__dialog {
      grid-template-columns: 1fr;
      grid-template-rows: 200px 1fr;
      max-height: calc(100dvh - 32px);
    }

    .dwg-welcome-banner__media {
      width: 100%;
      height: 200px;
      min-height: 200px;
      /* Bias the crop slightly upward so the chef's face/bottle stay in frame */
      background-position: center 28%;
    }

    .dwg-welcome-banner__panel {
      padding: 28px 22px 24px;
      overflow-y: auto;
    }

    .dwg-welcome-banner__close {
      top: 10px;
      right: 10px;
      width: 32px;
      height: 32px;
      /* Sits over the image — make sure it stays readable */
      background-color: rgba(255, 255, 255, 0.92);
    }

    .dwg-welcome-banner__brand {
      margin-bottom: 18px;
      font-size: 0.72rem;
      letter-spacing: 0.28em;
    }

    .dwg-welcome-banner__title {
      font-size: 1.5rem;
