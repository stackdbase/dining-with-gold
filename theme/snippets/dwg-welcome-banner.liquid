{% javascript %}
  (function () {
    var banner = document.getElementById('dwg-welcome-banner');
    if (!banner) return;

    var SESSION_KEY = 'dwg-welcome-banner-session-dismissed';
    var PERMANENT_KEY = 'dwg-welcome-banner-signed-up';
    var PAGEVIEWS_KEY = 'dwg-welcome-banner-page-views';
    // Strategic show schedule (page views in the current session).
    // The banner appears the first time, again after a bit of browsing,
    // and once more for engaged users — capped at 3 shows per session.
    var SHOW_AT_PAGEVIEWS = [1, 4, 8];
    var SHOW_DELAY_MS = 1500;
    var CLOSE_TRANSITION_MS = 320;
    var dismissEls = banner.querySelectorAll('[data-dwg-dismiss]');
    var dismissSessionEls = banner.querySelectorAll('[data-dwg-dismiss-session]');
    var justSubmitted = banner.getAttribute('data-just-submitted') === 'true';

    function isPermanentlyDismissed() {
      try { return window.localStorage.getItem(PERMANENT_KEY) === '1'; } catch (e) { return false; }
    }

    function isSessionDismissed() {
      try { return window.sessionStorage.getItem(SESSION_KEY) === '1'; } catch (e) { return false; }
    }

    function rememberPermanent() {
      try { window.localStorage.setItem(PERMANENT_KEY, '1'); } catch (e) {}
    }

    function rememberSession() {
      try { window.sessionStorage.setItem(SESSION_KEY, '1'); } catch (e) {}
    }

    function incrementPageViews() {
      try {
        var current = parseInt(window.sessionStorage.getItem(PAGEVIEWS_KEY) || '0', 10) || 0;
        var next = current + 1;
        window.sessionStorage.setItem(PAGEVIEWS_KEY, String(next));
        return next;
      } catch (e) { return 1; }
    }

    function shouldShowAtPageView(n) {
      for (var i = 0; i < SHOW_AT_PAGEVIEWS.length; i++) {
        if (SHOW_AT_PAGEVIEWS[i] === n) return true;
      }
      return false;
    }

    function show() {
      banner.classList.add('is-visible');
      document.documentElement.style.overflow = 'hidden';
    }

    function hide() {
      // Plain dismiss — does NOT persist. Pop-up returns on next page load.
      banner.classList.remove('is-visible');
      document.documentElement.style.overflow = '';
      setTimeout(function () {
        banner.style.display = 'none';
      }, CLOSE_TRANSITION_MS);
    }

    function dismissForSession() {
      rememberSession();
      hide();
    }

    // Skip rendering if user already signed up (permanent) or chose
    // "Don't Show Me Again" this session.
    if ((isPermanentlyDismissed() || isSessionDismissed()) && !justSubmitted) {
      banner.style.display = 'none';
      return;
    }

    // Strategic show throttle: count every page view in this session
    // and only show on pre-defined trigger views (e.g. 1st, 4th, 8th).
    // After 3 shows in a session, the banner stays hidden for that session
    // even if the user keeps browsing.
    var pageViews = incrementPageViews();
    if (!justSubmitted && !shouldShowAtPageView(pageViews)) {
      banner.style.display = 'none';
      return;
    }

    // Plain dismissals (X / NO THANKS / overlay click)
    dismissEls.forEach(function (el) {
      el.addEventListener('click', hide);
    });

    // Session-dismissal button ("DON'T SHOW ME AGAIN")
    dismissSessionEls.forEach(function (el) {
      el.addEventListener('click', dismissForSession);
    });

    // ESC closes (no persistence)
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && banner.classList.contains('is-visible')) {
        hide();
      }
    });

    function reveal() {
      window.requestAnimationFrame(function () {
        setTimeout(show, SHOW_DELAY_MS);
      });
    }

    /* Silently apply the WELCOME10 discount to the user's cart session.
       Shopify's /discount/CODE endpoint applies the code as a server-side
       cart attribute and then redirects. fetch() with default redirect
       behavior + no-cors mode is enough to trigger the apply without
       navigating away from this page. */
    function applyWelcomeDiscount() {
      try {
        fetch('/discount/WELCOME10', { credentials: 'same-origin', mode: 'no-cors' })
          .catch(function () {});
      } catch (e) {}
    }

    /* Click-to-copy the discount code in the reward modal. Binds both the
       code text itself and the "COPY DISCOUNT CODE" button. */
    var COPY_CODE = 'WELCOME10';
    var copyEls = banner.querySelectorAll('[data-dwg-copy-code]');
    copyEls.forEach(function (el) {
      el.addEventListener('click', function () {
        var clickedBtn = el;
        try {
          if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(COPY_CODE);
          } else {
            var ta = document.createElement('textarea');
            ta.value = COPY_CODE;
            ta.setAttribute('readonly', '');
            ta.style.position = 'absolute';
            ta.style.left = '-9999px';
            document.body.appendChild(ta);
            ta.select();
            document.execCommand('copy');
            document.body.removeChild(ta);
          }
          var original = clickedBtn.textContent;
          clickedBtn.textContent = 'COPIED!';
          setTimeout(function () { clickedBtn.textContent = original; }, 1500);
        } catch (e) {}
      });
    });

    if (justSubmitted) {
      // Successful signup: persist permanently so it never returns.
      rememberPermanent();
      // Apply the 10% discount to the user's cart in the background, so
      // even if the user just dismisses without clicking Apply, their cart
      // already has the code on it.
      applyWelcomeDiscount();
      show();
      // No auto-close for the reward — user dismisses manually via X /
      // overlay / Esc, or by clicking Copy/Apply.
    } else if (document.readyState === 'complete' || document.readyState === 'interactive') {
      reveal();
    } else {
      window.addEventListener('DOMContentLoaded', reveal);
    }
  })();
{% endjavascript %}
